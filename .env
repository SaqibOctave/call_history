PORT=8790

# Logging (error, warn, info, debug)
LOG_LEVEL=info
LOG_TO_FILE=false

# Request body size limit
BODY_LIMIT=10mb

# JWT
JWT_ACCESS_SECRET=octavebytes
JWT_REFRESH_SECRET=octavebytes_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_HTTP_ONLY=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_MAX_AGE_DAYS=7

# PostgreSQL
DB_HOST=84.46.251.98
DB_PORT=5432
DB_USER=faraz
DB_PASSWORD=mypass
DB_NAME=faraz